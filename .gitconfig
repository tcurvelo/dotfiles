[user]
	name = Thiago Curvelo
	email = tcurvelo@gmail.com

[includeIf "gitdir:~/workspace/tucows/"]
	path = ~/.gitconfig-tc

[alias]
	lg = log --graph --all --format=format:'%C(bold blue)%h%C(reset) - %C(blue)(%ar)%C(reset) %C(bold blue)%s%C(reset) %C(bold)— %an%C(reset)%C(bold yellow)%d%C(reset)' --abbrev-commit --date=relative

[core]
	editor = code --wait
	excludesfile = ~/.gitignore_global
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	features = line-numbers hyperlinks decorations
	hyperlinks-file-link-format = "vscode://file/{path}:{line}"
	navigate = true
	plus-style                    = syntax "#002b36"
	plus-non-emph-style           = syntax "#002b36"
	plus-emph-style               = bold white "#005f87"
	line-numbers-plus-style       = "#00afff"

[push]
	default = current

[credential]
	helper = cache

[color]
	ui = true

[pull]
	ff = only
	rebase = true

[init]
	defaultBranch = main

[rebase]
	autostash = true

[commit]
	verbose = true

[diff]
	algorithm = histogram

[url "ssh://git@github.com/tucowsinc"]
	insteadOf = https://github.com/tucowsinc
